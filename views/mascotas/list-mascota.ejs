<%- include('../components/header.ejs') %>
    <div class="container">
        <div class="row mt-2">
            <div class="col">
                <div class="card">
                    <div class="card-body">
                        <div class="card-title">
                            <h1>Lista de Mascotas</h1>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-striped" id="tblMascotas">
                                <thead>
                                    <tr>
                                        <th>Id</th>
                                        <th>Nombre</th>
                                        <th>Tipo</th>
                                        <th></th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% mascotas.forEach(mascota=> { %>
                                        <tr>
                                            <td>
                                                <%= mascota.id %>
                                            </td>
                                            <td>
                                                <%= mascota.nombre %>
                                            </td>
                                            <td>
                                                <%= mascota.tipo %>
                                            </td>
                                            <td>
                                                <a class="btn btn-primary" href="/mascotas/<%=mascota.id%>">
                                                    Editar
                                                </a>
                                            </td>
                                            <td>
                                                <form onsubmit="return confirm('Está seguro que desea eliminar?')"
                                                    action="/mascotas/<%=mascota.id%>/delete" method="post">
                                                    <button class="btn btn-danger" type="submit">
                                                        Eliminar
                                                    </button>   
                                                </form>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('../components/footer.ejs') %>